let currentFilter = 'all';

function setFilter(cat, btn) {
  currentFilter = cat;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyFilters();
}

function applyFilters() {
  const q = document.getElementById('searchInput').value.toLowerCase().trim();
  const filtered = DATA.filter(d => {
    const matchCat = currentFilter === 'all' || d.cat === currentFilter;
    const matchSearch = !q || d.name.toLowerCase().includes(q) || d.desc.toLowerCase().includes(q) || d.tags.some(t => t.toLowerCase().includes(q));
    return matchCat && matchSearch;
  });
  renderGrid(filtered);
  document.getElementById('resultsCount').textContent = filtered.length + ' resultado' + (filtered.length !== 1 ? 's' : '');
}

function renderGrid(items) {
  const grid = document.getElementById('beastGrid');
  const noRes = document.getElementById('noResults');
  if (!items.length) { grid.innerHTML=''; noRes.style.display='block'; return; }
  noRes.style.display='none';
  grid.innerHTML = items.map((d, i) => `
    <div class="beast-card ${d.cat}" onclick="openModal('${d.id}')" style="animation-delay:${i*0.04}s">
      ${d.available ? '' : '<div class="card-hidden"><div class="hide-icon">❓</div><div class="hide-txt">Por descubrir</div></div>'}
      <div class="card-status">${d.available ? '✅' : '❓'}</div>
      <div class="card-icon">${d.icon}</div>
      <div class="card-name">${d.name}</div>
      <div class="card-badge"><span class="badge ${d.cat}">${d.catLabel}</span></div>
      <div class="card-desc">${d.desc}</div>
    </div>`).join('');
}

function openModal(id) {
  const d = DATA.find(x => x.id === id);
  const catColors = { pura:'rgba(68,136,255,0.5);color:rgba(100,160,255,0.9)', corrupta:'rgba(204,0,255,0.5);color:rgba(220,100,255,0.9)', origen:'rgba(255,170,0,0.5);color:rgba(255,200,80,0.9)', jefe:'rgba(255,34,34,0.5);color:rgba(255,100,100,0.9)', npc:'rgba(255,80,80,0.4);color:rgba(255,140,140,0.8)' };
  const cc = catColors[d.cat];
  document.getElementById('modalContent').innerHTML = `
    <div class="modal-header">
      <button class="modal-close" onclick="closeModal()">✕</button>
      <div class="modal-icon">${d.icon}</div>
      <div class="modal-title">${d.name}</div>
      <span class="modal-cat" style="border-color:${cc}">${d.catLabel}</span>
    </div>
    <div class="modal-body">
      <div class="info-row"><div class="info-key">Lore</div><div class="info-val lore">${d.lore}</div></div>
      <div class="info-row"><div class="info-key">Estilo</div><div class="info-val">${d.style}</div></div>
      <div class="info-row"><div class="info-key">Pasiva</div><div class="info-val" style="color:rgba(255,140,0,0.4);font-style:italic;">Por revelar — ¡contribuye a la wiki!</div></div>
      <div class="info-row"><div class="info-key">Estado</div><div class="info-val">${d.available ? '✅ Disponible en juego' : '❓ Aún por descubrir — explora el mundo'}</div></div>
      <div class="info-row"><div class="info-key">Tags</div><div class="info-val"><div class="tag-row">${d.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div></div></div>
      <div class="modal-divider"></div>
      <div class="modal-tip">
        <div class="modal-tip-label">🔥 Consejo de la Wiki</div>
        <div class="modal-tip-text">${d.tip}</div>
      </div>
      ${d.cat !== 'jefe' && d.cat !== 'npc' ? `<div style="text-align:center;"><a class="modal-roblox" href="https://www.roblox.com/es/games/103451711855402/BESTIAS-Y-MONSTRUOS" target="_blank">🎮 Jugar en Roblox</a></div>` : ''}
    </div>`;
  document.getElementById('modal').classList.add('open');
}
function closeModal() { document.getElementById('modal').classList.remove('open'); }
document.addEventListener('keydown', e => { if(e.key==='Escape') closeModal(); });

// PARTICLES
const canvas = document.getElementById('particles'), ctx = canvas.getContext('2d');
let W = canvas.width = window.innerWidth, H = canvas.height = window.innerHeight;
window.addEventListener('resize', ()=>{ W=canvas.width=window.innerWidth; H=canvas.height=window.innerHeight; });
const embers = Array.from({length:65}, ()=>({
  x:Math.random()*window.innerWidth, y:window.innerHeight+Math.random()*100,
  size:Math.random()*2+0.4, speed:Math.random()*0.65+0.18,
  drift:(Math.random()-0.5)*0.35, alpha:Math.random()*0.5+0.08, hue:Math.random()*60+5
}));
function drawEmbers(){
  ctx.clearRect(0,0,W,H);
  embers.forEach(e=>{
    e.y-=e.speed; e.x+=e.drift;
    e.alpha+=(Math.random()-0.5)*0.018;
    e.alpha=Math.max(0.04,Math.min(0.6,e.alpha));
    if(e.y<-10){e.y=H+10;e.x=Math.random()*W;}
    ctx.beginPath(); ctx.arc(e.x,e.y,e.size,0,Math.PI*2);
    ctx.fillStyle=`hsla(${e.hue},100%,60%,${e.alpha})`; ctx.fill();
  });
  requestAnimationFrame(drawEmbers);
}
drawEmbers();

// INIT
applyFilters();
document.getElementById('resultsCount').textContent = DATA.length + ' resultados';
</script>
</body>
</html>
